{
  "manifest_version": 3,
  "name": "AI Comment Assistant",
  "version": "1.0",
  "description": "Generate AI-powered comment drafts on Reddit and Instagram.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://www.reddit.com/*",
    "https://www.instagram.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.reddit.com/*",
        "https://www.instagram.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}